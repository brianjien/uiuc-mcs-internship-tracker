{
  "name": "internship-tracker",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build && node scripts/build-server.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "start": "node server/http.mjs",
    "wasmer:local": "npm run build && wasmer run . --net --env PORT=8080",
    "wasmer:deploy": "npm run build && wasmer deploy"
  },
  "dependencies": {
    "@vitejs/plugin-react": "5.0.4",
    "mysql2": "^3.22.5",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-icons": "^5.6.0",
    "vite": "6.4.2"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
