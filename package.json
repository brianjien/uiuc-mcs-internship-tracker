{
  "name": "career-tracker-dashboard",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "start": "python3 app.py",
    "test": "python3 -m unittest discover -s tests",
    "wasmer:local": "npm run build && wasmer run . --net --env PORT=8080",
    "wasmer:deploy": "node scripts/deploy-wasmer-flask.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "5.0.4",
    "google-auth-library": "^10.7.0",
    "mysql2": "^3.22.5",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-icons": "^5.6.0",
    "vite": "6.4.2"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
